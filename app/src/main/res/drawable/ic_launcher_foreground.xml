<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Camera lens outer golden bezel -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,54 m -24,0 a 24,24 0 1,1 48,0 a 24,24 0 1,1 -48,0"
        android:strokeWidth="2.5"
        android:strokeColor="#FFB300" />
    <!-- Inner blue glass element -->
    <path
        android:pathData="M 54,54 m -18,0 a 18,18 0 1,1 36,0 a 18,18 0 1,1 -36,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="36"
                android:startY="36"
                android:endX="72"
                android:endY="72"
                android:type="linear">
                <item android:offset="0" android:color="#FF4081"/>
                <item android:offset="1" android:color="#2979FF"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- Aperture blades reflections -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 46,42 L 54,39 L 52,47 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 62,46 L 69,52 L 61,54 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 50,66 L 43,60 L 51,58 Z" />
    <!-- Center camera iris indicator point -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,54 m -3,0 a 3,3 0 1,1 6,0 a 3,3 0 1,1 -6,0" />
    <!-- Target Photosphere bracket alignment sights -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 22,54 L 30,54"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:fillColor="#00000000"
        android:pathData="M 78,54 L 86,54"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,22 L 54,30"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,78 L 54,86"
        android:strokeWidth="2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
</vector>
